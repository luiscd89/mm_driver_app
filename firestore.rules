rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isAdmin()    { return isSignedIn() && request.auth.token.role == 'admin'; }
    function isSelf(uid)  { return isSignedIn() && request.auth.uid == uid; }

    match /drivers/{uid} {
      allow read:   if isSelf(uid) || isAdmin();
      allow list:   if isAdmin();
      allow create: if isSelf(uid);
      allow update: if isSelf(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /driverLocations/{uid} {
      allow read:   if isAdmin();
      allow write:  if isSelf(uid);
    }

    match /routes/{loadId} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      // Drivers may only flip confirmed/dispatched on their own routes.
      // Admins may edit anything.
      allow update: if isAdmin() ||
        (isSignedIn() &&
         resource.data.driver_uid == request.auth.uid &&
         request.resource.data.driver_uid == resource.data.driver_uid &&
         request.resource.data.date == resource.data.date &&
         request.resource.data.load_id == resource.data.load_id &&
         request.resource.data.route == resource.data.route);
    }

    match /gasReceipts/{id} {
      allow read:   if isAdmin() ||
        (isSignedIn() && resource.data.driver_uid == request.auth.uid);
      allow list:   if isAdmin() || isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.driver_uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
