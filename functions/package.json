{
  "name": "mtn-driver-functions",
  "version": "1.0.0",
  "description": "Cloud Functions backend for the MTN Driver app",
  "main": "index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "serve": "firebase emulators:start --only functions,firestore,auth,storage",
    "shell": "firebase functions:shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "seed": "node seed.js",
    "setAdmin": "node setAdmin.js"
  },
  "dependencies": {
    "@google/genai": "^1.50.0",
    "firebase-admin": "^12.6.0",
    "firebase-functions": "^5.1.0"
  },
  "private": true
}
